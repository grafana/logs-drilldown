{
  "extends": "./.config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "moduleResolution": "bundler",
    "module": "ES2015"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "target": "es5",
      "esModuleInterop": true,
      "moduleResolution": "node"
    },
    "transpileOnly": true
  }
}
